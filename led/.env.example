# 后端环境配置示例
# 复制此文件为 .env 并修改相应配置

# 服务端口
PORT=8080

# 数据库配置
# SQLite 配置（默认）
DB_TYPE=sqlite
DB_PATH=./db/goview.db

# MySQL 配置（如使用 MySQL）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=goview
# DB_USER=root
# DB_PASSWORD=your_password

# JWT 密钥（生产环境请修改）
JWT_SECRET=your-secret-key-change-in-production

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS 配置
CORS_ORIGIN=*
